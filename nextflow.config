// ============================================================
// nextflow.config – RNASeq Insight Platform – Arabidopsis thaliana
// ============================================================

manifest {
    name        = 'RNASeq-Insight-Arabidopsis'
    description = 'Pipeline RNA-Seq para Arabidopsis thaliana TAIR10'
    author      = 'Eulalio Santos – UFV'
    version     = '1.0.0'
    nextflowVersion = '>=24.04'
}

// ── Parâmetros padrão ─────────────────────────────────────────
params {
    // ── Inputs ──────────────────────────────────────────────
    samplesheet  = 'samplesheet.csv'
    genome_fasta = ''
    genome_gtf   = ''
    genome_gff3  = ''
    genome_index = ''

    // ── Contraste ───────────────────────────────────────────
    control_group   = 'WT'
    treatment_group = 'mutant'

    // ── Qualidade / Trimagem ─────────────────────────────────
    min_length = 36
    quality    = 20

    // ── featureCounts ────────────────────────────────────────
    feature_type = 'exon'
    gene_attr    = 'gene_id'
    strandedness = 0        // 0=unstranded, 1=stranded, 2=reversely-stranded

    // ── Análise R ────────────────────────────────────────────
    padj_cutoff    = 0.05
    lfc_cutoff     = 1.0
    kegg_organism  = 'ath'   // Arabidopsis thaliana
    report_title   = 'RNASeq – Arabidopsis thaliana TAIR10'
    report_author  = 'Eulalio Santos'

    // ── rMATS ────────────────────────────────────────────────
    read_length = 150

    // ── Output ──────────────────────────────────────────────
    outdir = 'results'
}

// ── Profiles ──────────────────────────────────────────────────
profiles {

    local {
        process {
            executor = 'local'
            cpus     = { Math.min(8,  Runtime.runtime.availableProcessors()) }
            memory   = { Math.min(32, Runtime.runtime.totalMemory() / 1e9 as int) + ' GB' }
        }
        conda.enabled = true
        conda.useMamba = true
    }

    slurm {
        process {
            executor     = 'slurm'
            queue        = 'batch'
            time         = '24h'

            withLabel: 'low_mem'    { cpus = 2;  memory = '8 GB'  }
            withLabel: 'medium_mem' { cpus = 8;  memory = '32 GB' }
            withLabel: 'high_mem'   { cpus = 16; memory = '64 GB' }
        }
        conda.enabled  = true
        conda.useMamba = true
    }

    test {
        params {
            samplesheet     = 'test/samplesheet_test.csv'
            genome_fasta    = 'test/genome_test.fa'
            genome_gff3     = 'test/annotation_test.gff3'
            genome_index    = ''
            control_group   = 'WT'
            treatment_group = 'mutant'
            read_length     = 50
            outdir          = 'test/results'
        }
        process {
            executor = 'local'
            cpus     = 2
            memory   = '4 GB'
        }
        conda.enabled = true
        conda.useMamba = true
    }
}

// ── Ambientes Conda por processo ──────────────────────────────
process {
    withName: 'FASTQC.*'        { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'MULTIQC.*'       { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'FASTP'           { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'GFFREAD'         { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'HISAT2.*'        { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'SAMTOOLS.*'      { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'FEATURECOUNTS'   { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'PARSE_COUNTS'    { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'RMATS'           { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'PARSE_RMATS'     { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'DESEQ2'          { conda = "${projectDir}/envs/r-analysis.yml"   }
    withName: 'ENRICHMENT'      { conda = "${projectDir}/envs/r-analysis.yml"   }
    withName: 'WGCNA'           { conda = "${projectDir}/envs/r-analysis.yml"   }
    withName: 'INTEGRATION'     { conda = "${projectDir}/envs/r-analysis.yml"   }
    withName: 'QUARTO_REPORT'   { conda = "${projectDir}/envs/r-analysis.yml"   }
}

// ── Relatórios de execução ────────────────────────────────────
timeline { enabled = true; file = "${params.outdir}/nextflow_timeline.html" }
report   { enabled = true; file = "${params.outdir}/nextflow_report.html"   }
trace    { enabled = true; file = "${params.outdir}/nextflow_trace.txt"     }
dag      { enabled = true; file = "${params.outdir}/nextflow_dag.html"      }
