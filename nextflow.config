// ============================================================
// nextflow.config – RNASeq Insight Platform – Arabidopsis thaliana
// ============================================================

manifest {
    name        = 'RNASeq-Insight-Arabidopsis'
    description = 'Pipeline RNA-Seq para Arabidopsis thaliana TAIR10'
    author      = 'Eulalio Santos – UFV'
    version     = '2.0.0'
    nextflowVersion = '>=24.04'
}

// ── Parâmetros padrão ─────────────────────────────────────────
params {
    // ── Inputs ──────────────────────────────────────────────
    samplesheet  = 'samplesheet.csv'
    genome_fasta = ''
    genome_gtf   = ''
    genome_gff3  = ''
    genome_index = ''

    // ── Contraste ───────────────────────────────────────────
    control_group   = 'WT'
    treatment_group = 'mutant'

    // ── Qualidade / Trimagem ─────────────────────────────────
    min_length = 36
    quality    = 20

    // ── Alinhador principal ('star' | 'hisat2') ──────────────
    aligner = 'star'

    // ── featureCounts ────────────────────────────────────────
    feature_type = 'exon'
    gene_attr    = 'gene_id'
    strandedness = 0        // 0=unstranded, 1=stranded, 2=reversely-stranded

    // ── Salmon (pseudoalinhamento) ────────────────────────────
    run_salmon = true       // Roda Salmon em paralelo para validação

    // ── Análise R ────────────────────────────────────────────
    padj_cutoff    = 0.05
    lfc_cutoff     = 1.0
    kegg_organism  = 'ath'   // Arabidopsis thaliana
    report_title   = 'RNASeq – Arabidopsis thaliana TAIR10'
    report_author  = 'Eulalio Santos'

    // ── Batch correction ─────────────────────────────────────
    run_combat_seq = true   // Detecta e corrige batch automaticamente

    // ── StringTie (montagem de transcritos) ──────────────────
    run_stringtie = false   // Desativado por padrão (Fase 2)

    // ── rMATS ────────────────────────────────────────────────
    read_length = 150

    // ── Output ──────────────────────────────────────────────
    outdir = 'results'
}

// ── Profiles ──────────────────────────────────────────────────
profiles {

    local {
        process {
            executor = 'local'
            cpus     = { Math.min(8,  Runtime.runtime.availableProcessors()) }
            memory   = { Math.min(32, Runtime.runtime.totalMemory() / 1e9 as int) + ' GB' }
        }
        conda.enabled = true
        conda.useMamba = true
    }

    slurm {
        process {
            executor     = 'slurm'
            queue        = 'batch'
            time         = '24h'

            withLabel: 'low_mem'     { cpus = 2;  memory = '8 GB';  time = '1h'  }
            withLabel: 'medium_mem'  { cpus = 8;  memory = '32 GB'; time = '4h'  }
            withLabel: 'high_mem'    { cpus = 16; memory = '64 GB'; time = '12h' }
            withLabel: 'star_index'  { cpus = 16; memory = '32 GB'; time = '1h'  }
            withLabel: 'star_align'  { cpus = 16; memory = '16 GB'; time = '2h'  }
            withLabel: 'salmon_idx'  { cpus = 8;  memory = '8 GB';  time = '30m' }
            withLabel: 'salmon_q'    { cpus = 8;  memory = '8 GB';  time = '30m' }
            withLabel: 'combat_seq'  { cpus = 2;  memory = '8 GB';  time = '30m' }
            withLabel: 'goseq'       { cpus = 2;  memory = '4 GB';  time = '20m' }
            withLabel: 'stringtie'   { cpus = 8;  memory = '8 GB';  time = '1h'  }
            withLabel: 'gffcompare'  { cpus = 4;  memory = '8 GB';  time = '30m' }
        }
        conda.enabled  = true
        conda.useMamba = true
    }

    test {
        params {
            samplesheet     = 'test/samplesheet_test.csv'
            genome_fasta    = 'test/genome_test.fa'
            genome_gff3     = 'test/annotation_test.gff3'
            genome_index    = ''
            control_group   = 'WT'
            treatment_group = 'mutant'
            read_length     = 50
            outdir          = 'test/results'
        }
        process {
            executor = 'local'
            cpus     = 2
            memory   = '4 GB'
        }
        conda.enabled = true
        conda.useMamba = true
    }
}

// ── Ambientes Conda por processo ──────────────────────────────
process {
    // ── Ferramentas bioinformáticas ─────────────────────────
    withName: 'FASTQC.*'        { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'MULTIQC.*'       { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'FASTP'           { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'GFFREAD'         { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    // Alinhadores
    withName: 'HISAT2.*'        { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'STAR.*'          { conda = "${projectDir}/envs/rnaseq-tools.yml"; label = 'star_align' }
    withName: 'STAR_INDEX'      { conda = "${projectDir}/envs/rnaseq-tools.yml"; label = 'star_index' }
    withName: 'SAMTOOLS.*'      { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    // Quantificação
    withName: 'FEATURECOUNTS'   { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'PARSE_COUNTS'    { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'SALMON.*'        { conda = "${projectDir}/envs/rnaseq-tools.yml"; label = 'salmon_q' }
    withName: 'SALMON_INDEX'    { conda = "${projectDir}/envs/rnaseq-tools.yml"; label = 'salmon_idx' }
    withName: 'TXIMPORT'        { conda = "${projectDir}/envs/r-analysis.yml" }
    // Splicing
    withName: 'RMATS'           { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'PARSE_RMATS'     { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    withName: 'RMATS_FILTER'    { conda = "${projectDir}/envs/rnaseq-tools.yml" }
    // Montagem de transcritos
    withName: 'STRINGTIE'       { conda = "${projectDir}/envs/rnaseq-tools.yml"; label = 'stringtie'  }
    withName: 'GFFCOMPARE'      { conda = "${projectDir}/envs/rnaseq-tools.yml"; label = 'gffcompare' }
    // ── Análise R ───────────────────────────────────────────
    withName: 'DESEQ2'          { conda = "${projectDir}/envs/r-analysis.yml" }
    withName: 'ENRICHMENT'      { conda = "${projectDir}/envs/r-analysis.yml" }
    withName: 'GOSEQ'           { conda = "${projectDir}/envs/r-analysis.yml"; label = 'goseq' }
    withName: 'WGCNA'           { conda = "${projectDir}/envs/r-analysis.yml" }
    withName: 'INTEGRATION'     { conda = "${projectDir}/envs/r-analysis.yml" }
    withName: 'QUARTO_REPORT'   { conda = "${projectDir}/envs/r-analysis.yml" }
    withName: 'COMBAT_SEQ'      { conda = "${projectDir}/envs/r-analysis.yml"; label = 'combat_seq' }
}

// ── Relatórios de execução ────────────────────────────────────
timeline { enabled = true; overwrite = true; file = "${params.outdir}/nextflow_timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/nextflow_report.html"   }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/nextflow_trace.txt"     }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/nextflow_dag.html"      }
